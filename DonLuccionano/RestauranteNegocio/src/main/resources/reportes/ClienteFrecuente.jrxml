	<dataset name="Dataset1" uuid="296e2bc5-24d3-4b47-9c13-66a64b574c2a">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Reportes"/>
		<parameter name="nombre" class="java.lang.String">
			<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
		</parameter>
		<parameter name="visitas" class="java.lang.String">
			<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
		</parameter>
		<query language="SQL"><![CDATA[SELECT 
    cf.nombre, 
    cf.total_visitas, 
    cf.total_gastado, 
    MAX(co.fecha) AS ultima_visita
FROM cliente_frecuente cf
INNER JOIN comandas co
    ON cf.id_cliente_frecuente = co.id_cliente_frecuente
WHERE 
    ($P{nombre} IS NULL OR cf.nombre LIKE CONCAT('%', $P{nombre}, '%'))
AND 
    ($P{visitas} IS NULL OR cf.total_visitas = $P{visitas})
GROUP BY 
    cf.id_cliente_frecuente, 
    cf.nombre, 
    cf.total_visitas, 
    cf.total_gastado]]></query>
		<field name="nombre" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="nombre"/>
			<property name="com.jaspersoft.studio.field.label" value="nombre"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="cliente_frecuente"/>
		</field>
		<field name="total_visitas" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="total_visitas"/>
			<property name="com.jaspersoft.studio.field.label" value="total_visitas"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="cliente_frecuente"/>
		</field>
		<field name="total_gastado" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.name" value="total_gastado"/>
			<property name="com.jaspersoft.studio.field.label" value="total_gastado"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="cliente_frecuente"/>
		</field>
		<field name="ultima_visita" class="java.sql.Date">
			<property name="com.jaspersoft.studio.field.name" value="ultima_visita"/>
			<property name="com.jaspersoft.studio.field.label" value="ultima_visita"/>
		</field>
	</dataset>
	<parameter name="nombre" class="java.lang.String">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="visitas" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[select 1 as numero]]></query>
	<field name="numero" class="java.lang.Long">
